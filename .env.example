# Copie este arquivo para ".env.local" (desenvolvimento) e preencha com os
# valores reais do seu projeto Supabase (Project Settings > API).
# Em produção (Coolify), essas mesmas variáveis são configuradas na aba
# "Environment Variables" do recurso — não use este arquivo em produção.

# URL do projeto Supabase, ex.: https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Chave pública "anon" do Supabase (Project Settings > API > Project API keys)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave "service_role" — NUNCA exponha no client, usada só em Server Actions.
# Mantenha em segredo; se vazar, gere uma nova no painel do Supabase.
SUPABASE_SERVICE_ROLE_KEY=

# Usadas apenas se for rodar migrations via CLI/psql (não são lidas pelo app em runtime)
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres"
